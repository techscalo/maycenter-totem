# PLANTILLA de variables de entorno (valores de EJEMPLO, no reales).
# Copiá este archivo a .env y completá con los valores reales.
#
# IMPORTANTE: la plantilla va en .env.example (no en .env.local), porque Vite
# carga .env.local con MÁS prioridad que .env y pisaría los valores reales.
# .env (real) está en .gitignore; .env.example se versiona.

# --- Neon (Postgres) ---
# Connection string del branch. Usá el branch "staging" en desarrollo.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# --- Better Auth ---
# Secreto de sesión. Generar con: openssl rand -base64 32
BETTER_AUTH_SECRET="reemplazar-por-secreto-aleatorio"
# URL base de la app (debe coincidir con el puerto de dev: 8080)
BETTER_AUTH_URL="http://localhost:8080"
